# Copy to `.env` and fill in to enable real Sentinel-1 downloads.
# Without these the API automatically uses the physics-based synthetic source.

# Copernicus Data Space Ecosystem credentials (https://dataspace.copernicus.eu/)
CDSE_USERNAME=
CDSE_PASSWORD=

# Data source: "auto" | "synthetic" | "copernicus"
WINDFIELD_SOURCE=auto

# Default grid spacing of returned wind vectors, in kilometres
WINDFIELD_GRID_KM=2.0

# Where downloaded / cached products are stored
WINDFIELD_DATA_DIR=data
